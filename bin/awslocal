#!/usr/bin/env bash
# awslocal — Wrapper around AWS CLI that points to local KumoStack endpoint.
# After resource-creating commands succeed, prompts to add metrics to Grafana.
#
# Usage:
#   awslocal sqs create-queue --queue-name my-queue
#   awslocal lambda create-function --function-name my-fn ...
#   awslocal dynamodb create-table --table-name my-table ...
#   awslocal s3 mb s3://my-bucket
#   awslocal s3api create-bucket --bucket my-bucket
#   awslocal elasticache create-cache-cluster --cache-cluster-id my-cluster
#
# Environment variables:
#   MINISTACK_ENDPOINT     KumoStack URL         (default: http://localhost:4566)
#   AWSLOCAL_NO_TUI        Set to 1 to skip TUI  (default: 0)
#   AWSLOCAL_AUTO_GRAFANA  Set to 1 to auto-add  (default: 0)

ENDPOINT_URL="${MINISTACK_ENDPOINT:-http://localhost:4566}"
AWS_ACCESS_KEY_ID="${AWS_ACCESS_KEY_ID:-test}"
AWS_SECRET_ACCESS_KEY="${AWS_SECRET_ACCESS_KEY:-test}"
AWS_DEFAULT_REGION="${AWS_DEFAULT_REGION:-us-east-1}"
AWSLOCAL_NO_TUI="${AWSLOCAL_NO_TUI:-0}"

export AWS_ACCESS_KEY_ID AWS_SECRET_ACCESS_KEY AWS_DEFAULT_REGION

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../scripts" && pwd)"

# Run the actual AWS CLI command
aws --endpoint-url="$ENDPOINT_URL" "$@"
EXIT_CODE=$?

[[ $EXIT_CODE -ne 0 ]] && exit $EXIT_CODE
[[ "$AWSLOCAL_NO_TUI" == "1" ]] && exit 0

SERVICE="${1:-}"
SUBCMD="${2:-}"

# Helper: get value of a named flag from the arg list
_flag_value() {
  local flag="$1"; shift
  while [[ $# -gt 0 ]]; do
    [[ "$1" == "$flag" ]] && { echo "$2"; return; }
    shift
  done
}

GRAFANA_SERVICE=""
RESOURCE_NAME=""

case "${SERVICE}:${SUBCMD}" in
  sqs:create-queue)
    GRAFANA_SERVICE="sqs"
    RESOURCE_NAME="$(_flag_value --queue-name "$@")"
    ;;
  lambda:create-function)
    GRAFANA_SERVICE="lambda"
    RESOURCE_NAME="$(_flag_value --function-name "$@")"
    ;;
  dynamodb:create-table)
    GRAFANA_SERVICE="dynamodb"
    RESOURCE_NAME="$(_flag_value --table-name "$@")"
    ;;
  s3:mb)
    GRAFANA_SERVICE="s3"
    for arg in "$@"; do
      [[ "$arg" == s3://* ]] && RESOURCE_NAME="${arg#s3://}" && break
    done
    ;;
  s3api:create-bucket)
    GRAFANA_SERVICE="s3"
    RESOURCE_NAME="$(_flag_value --bucket "$@")"
    ;;
  ec2:run-instances)
    GRAFANA_SERVICE="ec2"
    # Extract InstanceId from JSON response by re-running with --output json
    INSTANCE_JSON=$(aws --endpoint-url="$ENDPOINT_URL" "$@" --output json 2>/dev/null)
    RESOURCE_NAME=$(echo "$INSTANCE_JSON" | python3 -c \
      "import sys,json; d=json.load(sys.stdin); print(d['Instances'][0]['InstanceId'])" 2>/dev/null)
    ;;
  elasticache:create-cache-cluster)
    GRAFANA_SERVICE="elasticache"
    RESOURCE_NAME="$(_flag_value --cache-cluster-id "$@")"
    ;;
esac

# Trigger TUI if we recognised a resource-creating command
if [[ -n "$GRAFANA_SERVICE" && -n "$RESOURCE_NAME" ]]; then
  TUI_ARGS=(--service "$GRAFANA_SERVICE" --name "$RESOURCE_NAME")
  [[ "$AWSLOCAL_AUTO_GRAFANA" == "1" ]] && TUI_ARGS+=(--yes)
  python3 "$SCRIPT_DIR/grafana_resource.py" "${TUI_ARGS[@]}"
fi

exit 0
